{
  "expo": {
      "name": "AlfredPawPalace",
    "slug": "petshop",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    
    "plugins": [
      [
        "expo-image-picker",
        {
          "photosPermission": "O app precisa de acesso à sua galeria para escolher fotos dos seus pets."
        }
      ]
    ],
    
    "updates": {
      "url": "https://u.expo.dev/e56c1d7b-1cf2-42d6-b81c-7210e0052277"
    },
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#FFF5E5"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FFF5E5"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.alfredpawpalace.app",
      "usesCleartextTraffic": true
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "e56c1d7b-1cf2-42d6-b81c-7210e0052277"
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    }
  }
}